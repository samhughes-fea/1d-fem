# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Results: many reference trees under post_processing/results/ are tracked; do not use a blanket ignore.
# Ephemeral local pytest/run_job outputs (timestamp+pid); use `git add -f` if one must be committed.
post_processing/results/test_*/
post_processing/results/pytest_*/
post_processing/results/job_smoke_*_20*/
post_processing/results/job_test_*/
post_processing/results/_dbg/
post_processing/results/dbg_*/

# Validation: do not ignore; allow tracking Abaqus generated scripts and result CSVs
#post_processing/validation_visualisers/abaqus/generated/
#post_processing/validation_visualisers/abaqus_results/

# Local Abaqus session/recorder artifacts
abaqus.rpy*
abaqus*.rec

# Root-level Abaqus job outputs generated during local validation runs
*_abaqus.com
*_abaqus.dat
*_abaqus.inp
*_abaqus.log
*_abaqus.msg
*_abaqus.odb
*_abaqus.prt
*_abaqus.sta

# Local validation-generated wrappers and extracted raw reference results
post_processing/validation_visualisers/abaqus/generated/run_*.py
post_processing/validation_visualisers/abaqus_results/*/

# Local validation result trees and generated plot outputs
post_processing/results/validation/
post_processing/results/job_benchmark_*_20*/
post_processing/validation_visualisers/deformation/deformation_plots/*.png
post_processing/validation_visualisers/section_forces/section_forces_plots/*.png

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
temp_*.py
*_temp.py
*.tmp

# Logs
#*.log
debug*.log

# Build artifacts
build/
dist/
*.egg-info/
